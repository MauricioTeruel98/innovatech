# ── Base de datos ──────────────────────────────────────────────────────────────
# Producción (Hostinger): los datos se obtienen en hPanel → Bases de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=u123456_innovatech
DB_USER=u123456_innovatech
DB_PASS=TuPasswordAqui

# ── App ────────────────────────────────────────────────────────────────────────
# URL base donde vive el backend (sin barra final)
# Local:       http://localhost/innova-backend
# Producción:  https://tudominio.com/backend
APP_URL=https://tudominio.com/backend

# Nombre de la cookie de sesión del admin
ADMIN_SESSION_NAME=innovatech_admin

# ── Ruta secreta del panel ─────────────────────────────────────────────────────
# Cambiá esto por algo único y no adivinable (sin barras)
# Evitá: admin, administrator, panel, dashboard, login, cms, backend, manage
# Ejemplos válidos: recursos-internos, gestion-x7k2, privado-cms-b9
PANEL_PATH=gestion-x7k2

# ── CORS ───────────────────────────────────────────────────────────────────────
# Dominio del frontend en producción (sin barra final)
CORS_ORIGIN=https://tudominio.com
